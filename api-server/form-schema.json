  {"name":"grade","label":"職級","widget":"radio","options":["初級","中級","資深"]},
  {"name":"active","label":"在職","widget":"checkbox"},
  {"name":"joined","label":"到職日","widget":"date"},
  {"name":"salary","label":"月薪","widget":"number",
